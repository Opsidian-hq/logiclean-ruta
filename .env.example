# ============================================================
# Logiclean Ruta — Variables de entorno
#
# INSTRUCCIONES:
# 1. Copia este archivo a .env.local
# 2. Reemplaza los placeholders con tus valores reales
# 3. NUNCA commitees .env.local ni credenciales reales
#
# La SUPABASE_SERVICE_ROLE_KEY nunca va en el cliente ni en el repo.
# ============================================================

# Supabase — proyecto en la nube
# Encuéntralos en: Settings → API en el dashboard de Supabase
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# URL de conexión directa a Postgres (solo para scripts de backup)
# NUNCA exponer al cliente. Solo en entornos CI/CD o scripts locales.
# Encuéntrarla en: Settings → Database → Connection string (URI)
SUPABASE_DB_URL=postgres://postgres:[PASSWORD]@db.tu-proyecto.supabase.co:5432/postgres

# URL pública del proyecto (para el script keepalive)
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
